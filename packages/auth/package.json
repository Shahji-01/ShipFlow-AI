    "lint": "eslint src/"
  },
  "dependencies": {
    "@shipflow/database": "workspace:*",
    "@shipflow/inngest": "workspace:*",
    "better-auth": "^1.1.14"
  },
  "devDependencies": {
    "@shipflow/eslint-config": "workspace:*",
    "@shipflow/typescript-config": "workspace:*",
    "@types/node": "^22.20.0",
    "eslint": "^9.16.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
